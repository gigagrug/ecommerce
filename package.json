{
  "name": "marketplace",
  "type": "module",
  "scripts": {
    "tw": "tailwindcss -i ./src/input.css -o ./static/output.css -m",
    "icons": "node ./src/generate-icons.js",
    "js": "esbuild ./src/app.js ./src/chart.js --bundle --minify --outdir=static",
    "build": "npm run icons && npm run tw && npm run js"
  },
  "dependencies": {
    "alpinejs": "^3.15.12",
    "chart.js": "^4.5.1",
    "lucide": "^1.16.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-go-template",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": [
          "*.html"
        ],
        "options": {
          "parser": "go-template"
        }
      }
    ],
    "printWidth": 1000
  }
}
